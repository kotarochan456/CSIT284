<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/linearlayoutRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#808080"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp"
    android:paddingTop="60dp">

    <ImageView
        android:id="@+id/imageviewProfilePicture"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="-50dp"
        android:elevation="5dp"
        android:src="@drawable/download" />

    <LinearLayout
        android:id="@+id/linearlayoutProfileCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/profile_card_bg"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        android:paddingBottom="30dp">

        <TextView
            android:id="@+id/textviewUsernameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/username_label"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textviewUsernameValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sample_username"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/textviewGmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gmail"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textviewGmailValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delacruz@gmail.com"
            android:textColor="#000000"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/textviewPasswordLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textviewPasswordValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="text"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/textviewDobLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date of Birth"
            android:textSize="12sp" />


        <TextView
            android:id="@+id/textviewGenderLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textviewGenderValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="text"
            android:textColor="#000000"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/textviewResumeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resume"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/textviewResumeFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#999999"
            android:padding="12dp"
            android:text="Resume.pdf"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="15dp" />

        <TextView
            android:id="@+id/textviewCertificationsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Certifications"
            android:layout_marginBottom="5dp" />

        <TextView
            android:id="@+id/textviewCertificatesFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#999999"
            android:padding="12dp"
            android:text="Certificates.pdf"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/buttonBack"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:backgroundTint="#808080"
            android:text="back"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
